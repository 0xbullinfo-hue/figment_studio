# ============================================================================
# ENVIRONMENT CONFIGURATION - Production Ready Setup
# Copy this to .env and fill in actual values
# DO NOT commit .env to git (keep only .env.example)
# ============================================================================

# ── NODE ──
NODE_ENV=development
PORT=8787
LOG_LEVEL=info

# ── DATABASE ──
# PostgreSQL connection string
# Format: postgres://user:password@localhost:5432/dbname
# Use: `psql postgresql://...` to connect
DATABASE_URL=postgresql://user:password@localhost:5432/figment_studio

# ── JWT & AUTHENTICATION ──
# Generate with: `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
JWT_SECRET=your_jwt_secret_32_chars_minimum_required_for_security
JWT_REFRESH_SECRET=your_refresh_secret_32_chars_minimum_required_for_security
ADMIN_EMAIL=adminxfcs@figmentstudio.ng
ADMIN_PASSWORD=AdminPass123!
CLIENT_EMAIL=client@figmentstudio.ng
CLIENT_PASSWORD=ClientPass123!

# ── PAYMENT PROVIDERS ──
# Get credentials from provider dashboards

# Paystack (for African markets primarily)
# Dashboard: https://dashboard.paystack.com/settings/api
PAYSTACK_SECRET_KEY=sk_live_... or sk_test_...
PAYSTACK_CHECKOUT_URL=https://checkout.paystack.com

# Flutterwave (for global & African payments)
# Dashboard: https://app.flutterwave.com/dashboard/settings/apis
FLUTTERWAVE_SECRET_KEY=FLWSECK_LIVE_... or FLWSECK_TEST_...
FLUTTERWAVE_CHECKOUT_URL=https://checkout.flutterwave.com
FLUTTERWAVE_WEBHOOK_HASH=your_flutterwave_webhook_hash

# ── CURRENCY & RATES ──
# Exchange rates for billing (USD to local currency)
FX_USD_NGN=1600

# ── AI SERVICES ──
# Google Gemini API
# Get from: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key
API_KEY=your_gemini_api_key (deprecated, use GEMINI_API_KEY)

# ── GOOGLE AUTH ──
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# ── CORS & SECURITY ──
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3005,http://localhost:5173,https://figmentstudio.ng
FRONTEND_URL=http://localhost:5173

# ── FILE STORAGE ──
# Option 1: AWS S3
S3_BUCKET=figment-studio-images
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Option 2: Cloudflare R2 (S3-compatible)
# CF_ACCOUNT_ID=
# CF_ACCESS_KEY_ID=
# CF_SECRET_ACCESS_KEY=

# ── EMAIL ──
# SendGrid for transactional emails (receipts, notifications)
SENDGRID_API_KEY=SG.xxxxxxx
SENDGRID_FROM_EMAIL=billing@figmentstudio.ng

# ── MONITORING & LOGGING ──
# DataDog (optional for production)
DATADOG_API_KEY=
DATADOG_APP_KEY=

# ── FEATURE FLAGS ──
# Enable/disable features per environment
ENABLE_PAYMENTS=true
ENABLE_AI_STUDIO=true
ENABLE_ADMIN_GALLERY=true
TRIAL_RENDER_LIMIT=4
